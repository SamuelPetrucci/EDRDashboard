# Copy to `.env` in the project root. Do not commit `.env`.
# Vercel: Project → Settings → Environment Variables (client vars use the `VITE_` prefix only).

# --- Supabase (browser) — Dashboard → Settings → API keys ---
# Project URL + publishable key (`sb_publishable_…`). Enables Auth and /app/* gate when both set.
# URL must be the project root only: https://YOUR_REF.supabase.co (do not append /rest/v1 or /auth/v1).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Legacy public JWT if your project still shows “anon” only (optional fallback in code).
# VITE_SUPABASE_ANON_KEY=

# --- Demo sign-in (optional) ---
# Shared password shown on /sign-in when Supabase is configured. Match the value used by npm run seed:demo.
# VITE_DEMO_PASSWORD=DRIS-Demo-2026!
# Hide the demo logins panel on /sign-in (any environment):
# VITE_HIDE_DEMO_LOGIN=1

# Service role / secret key (`sb_secret_…`) — seed scripts & server only. Never `VITE_*`.
# Name used in this repo’s seed script (either works):
# SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Mapbox — Account → Access tokens — default public token ---
VITE_MAPBOX_ACCESS_TOKEN=

# Legacy name still read if `VITE_MAPBOX_ACCESS_TOKEN` is unset:
# VITE_MAPBOX_TOKEN=

# --- Optional Intel / Overview APIs (Windy, AIS, news, radar, webcams, …) ---
# When unset or not "true", the app does NOT call third-party intel/overview feeds
# (OpenSky, AISHub, GDACS, USGS, geocode, Open-Meteo, Windy, news URL, webcams).
# Set to true only when keys and endpoints are configured. See MANUAL_SETUP.md.
# VITE_ENABLE_EXTERNAL_INTEL_FEEDS=true

# Windy Point Forecast only (National Overview weather card) — does not enable AIS/OpenSky/etc.
# Requires VITE_WINDY_FORECAST_API_KEY or VITE_WINDY_API_KEY. Implied when VITE_ENABLE_EXTERNAL_INTEL_FEEDS=true.
# VITE_ENABLE_WINDY_FORECAST=true
