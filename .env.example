# Copy to .env and fill in. Do not commit .env. For Vercel, set these in Project → Settings → Environment Variables.

# 3D Globe (Mapbox) – https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=

# Real AIS ships (AISHub) – https://www.aishub.net/
# VITE_AISHUB_USERNAME=
# VITE_AISHUB_KEY=

# Weather radar tile URL
# VITE_RAINVIEWER_TILE_URL=

# Windy – https://api.windy.com/keys
VITE_WINDY_FORECAST_API_KEY=
VITE_WINDY_WEBCAM_API_KEY=

# OpenWebcamDB – https://openwebcamdb.com/
# VITE_OPENWEBCAMDB_API_KEY=
